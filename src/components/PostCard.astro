---
import SportTag from './SportTag.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  slug: string;
  sports: string[];
}

const { title, description, pubDate, slug, sports } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="post-card">
  <a href={`/blog/${slug}`} class="post-card-link">
    <time datetime={pubDate.toISOString()}>{formattedDate}</time>
    <h3>{title}</h3>
    <p>{description}</p>
  </a>
  <div class="post-card-sports">
    {sports.map((sport) => <SportTag sport={sport} />)}
  </div>
</article>

<style>
  .post-card {
    padding: 1.5rem;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    transition: border-color 0.15s;
  }

  .post-card:hover {
    border-color: var(--color-primary);
  }

  .post-card-link {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .post-card-link:hover {
    text-decoration: none;
  }

  time {
    font-size: 0.85rem;
    color: var(--color-text-light);
  }

  h3 {
    font-size: 1.2rem;
    margin: 0.5rem 0 0.6rem;
    color: var(--color-text);
  }

  p {
    font-size: 0.95rem;
    color: var(--color-text-light);
    line-height: 1.6;
    margin-bottom: 0.75rem;
  }

  .post-card-sports {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }
</style>
