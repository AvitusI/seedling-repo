---
import BaseLayout from './BaseLayout.astro';
import SportTag from '../components/SportTag.astro';
import CTABox from '../components/CTABox.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  author: string;
  sports: string[];
  image?: string;
}

const { title, description, pubDate, author, sports, image } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const articleJsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  datePublished: pubDate.toISOString(),
  author: {
    '@type': 'Organization',
    name: author,
    url: 'https://seedlingsports.com',
  },
  publisher: {
    '@type': 'Organization',
    name: 'Seedling Sports',
    url: 'https://seedlingsports.com',
  },
  ...(image && { image }),
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': `https://seedlingsports.com/blog/${Astro.params.slug}/`,
  },
});
---

<BaseLayout title={`${title} | Seedling Sports`} description={description} ogType="article">
  <script type="application/ld+json" set:html={articleJsonLd} slot="head" />
  <article class="post container">
    <header class="post-header">
      <div class="post-meta">
        <time datetime={pubDate.toISOString()}>{formattedDate}</time>
        <span class="separator">&middot;</span>
        <span>{author}</span>
      </div>
      <h1>{title}</h1>
      <div class="post-sports">
        {sports.map((sport) => <SportTag sport={sport} />)}
      </div>
    </header>
    {image && <img src={image} alt="" class="post-image" />}
    <div class="prose">
      <slot />
    </div>
    <CTABox />
  </article>
</BaseLayout>

<style>
  .post {
    max-width: var(--max-width-prose);
    padding-top: 3rem;
    padding-bottom: 4rem;
  }

  .post-header {
    margin-bottom: 2.5rem;
  }

  .post-meta {
    color: var(--color-text-light);
    font-size: 0.9rem;
    margin-bottom: 0.75rem;
  }

  .separator {
    margin: 0 0.4rem;
  }

  h1 {
    font-size: 2.2rem;
    line-height: 1.2;
    margin-bottom: 1rem;
  }

  .post-sports {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .post-image {
    border-radius: 8px;
    margin-bottom: 2rem;
  }
</style>
