---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 6);
---

<BaseLayout title="Seedling Sports — Science-backed guidance for sports parents">
  <section class="hero">
    <div class="container">
      <h1>Science-backed guidance for sports parents</h1>
      <p class="hero-sub">
        Seedling Sports helps parents make confident, informed decisions about their child's
        athletic development — grounded in research, not hype.
      </p>
    </div>
  </section>

  <section class="container latest-posts">
    <h2>Latest Articles</h2>
    <div class="post-grid">
      {posts.map((post) => (
        <PostCard
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          slug={post.id}
          sports={post.data.sports}
        />
      ))}
    </div>
    <div class="view-all">
      <a href={`${import.meta.env.BASE_URL}/blog`}>View all articles &rarr;</a>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    background: var(--color-bg-warm);
    padding: 4rem 0;
    text-align: center;
  }

  .hero h1 {
    font-size: 2.5rem;
    max-width: 650px;
    margin: 0 auto 1rem;
    color: var(--color-primary);
  }

  .hero-sub {
    font-size: 1.15rem;
    color: var(--color-text-light);
    max-width: 550px;
    margin: 0 auto;
  }

  .latest-posts {
    padding: 3rem 0 4rem;
  }

  .latest-posts h2 {
    margin-bottom: 1.5rem;
  }

  .post-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.25rem;
  }

  .view-all {
    text-align: center;
    margin-top: 2rem;
  }

  .view-all a {
    font-weight: 600;
    font-size: 1rem;
  }

  @media (max-width: 600px) {
    .hero h1 {
      font-size: 1.8rem;
    }

    .hero {
      padding: 3rem 0;
    }

    .post-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
